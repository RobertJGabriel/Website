{
	"name": "robertgabriel.ninja",
	"version": "3.0.0",
	"description": "Personal site of Robert James Gabriel — Irish software engineer and founder of Helperbird. Built with Eleventy, Tailwind CSS and DaisyUI.",
	"scripts": {
		"clean": "rimraf docs src/assets/css/engine.css",
		"dev": "webpack && ELEVENTY_ENV=development eleventy --serve",
		"start": "ELEVENTY_ENV=development eleventy --serve",
		"format": "prettier --write .",
		"build": "NODE_ENV=production ELEVENTY_ENV=production webpack --mode production && ELEVENTY_ENV=production eleventy",
		"check:links": "node scripts/check-links.mjs"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/RobertJGabriel/robertjgabriel.github.io.git"
	},
	"keywords": [
		"eleventy",
		"11ty",
		"tailwindcss",
		"daisyui",
		"personal-site"
	],
	"author": "Robert James Gabriel",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/RobertJGabriel/robertjgabriel.github.io/issues"
	},
	"homepage": "https://www.robertgabriel.ninja",
	"devDependencies": {
		"@11ty/eleventy": "^3.0.0",
		"@11ty/eleventy-plugin-rss": "^2.0.2",
		"@babel/core": "^7.24.0",
		"@babel/preset-env": "^7.24.0",
		"@tailwindcss/postcss": "^4.1.4",
		"@tailwindcss/typography": "^0.5.16",
		"@toycode/markdown-it-class": "^1.2.4",
		"babel-loader": "^8.3.0",
		"daisyui": "^5.0.27",
		"html-minifier": "^4.0.0",
		"markdown-it": "^12.2.0",
		"markdown-it-anchor": "^9.2.0",
		"postcss": "^8.5.3",
		"prettier": "^2.8.4",
		"rimraf": "^3.0.2",
		"tailwindcss": "^4.1.4",
		"webpack": "^5.90.0",
		"webpack-cli": "^4.10.0"
	}
}
